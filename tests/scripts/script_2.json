      "voiceId": "BIvP0GN1cAtSRTxNHnWS",
      "text": "Do you want coffee? I'm making a pot."
    },
    {
      "speaker": "Mark",
      "voiceId": "UgBBYS2sOqTuMpoF3BR0",
      "text": "[enthusiastic] Yes please, I've been up since five."
    },
